# =============================================================================
# RAPIIN FRONTEND — Environment Variables Template
# =============================================================================
# Copy this file to .env or .env.local and fill in the values.
# =============================================================================

# Application URL (Frontend local port)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001

# API Base URL (Choose one depending on target backend environment)
# For Local Development API:
NEXT_PUBLIC_API_URL=http://localhost:3001

# For Production API (testing local FE with prod BE):
# NEXT_PUBLIC_API_URL=https://yourAPI.com

# Optional Analytics & Monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
