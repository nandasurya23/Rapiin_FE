# =============================================================================
# RAPIIN FRONTEND — Environment Variables Template
# =============================================================================
# Copy this file to .env or .env.local and fill in the values.
# =============================================================================

# Application URL (Frontend local port)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Base URL (Backend local port)
# The backend endpoints are located under /api (e.g., http://localhost:3001/api/auth/login)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Optional Analytics & Monitoring
NEXT_PUBLIC_SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
